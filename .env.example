# Copy this file to .env and replace all placeholder values with strong secrets before starting the services.

# Required: strong secret used to sign JWT tokens for both core-api and analytics-api.
# Must be at least 32 characters.
JWT_SECRET=replace-with-a-strong-random-secret-of-at-least-32-characters

# Required: shared secret used for authenticated backend-to-backend calls between core-api and analytics-api.
INTERNAL_API_KEY=replace-with-another-strong-random-secret

# Optional: third-party credentials for notifications. Without these, notifications are logged but not sent.
SENDGRID_KEY=
TWILIO_SID=
TWILIO_AUTH_TOKEN=

# Optional: sender identifiers for notifications.
SENDER_EMAIL=noreply@waybilltracking.com
SENDER_PHONE=+12025551234

# Optional: recipient for daily reports and anomaly alerts.
REPORT_EMAIL=ops@waybilltracking.com

# Optional: public URL of the dashboard used in password reset emails.
FRONTEND_URL=http://localhost:3010
