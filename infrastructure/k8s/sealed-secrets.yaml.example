apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: waybill-secrets
  namespace: waybill
spec:
  encryptedData:
    # Generated with:
    #   kubectl create secret generic waybill-secrets \
    #     --from-literal=database-url="postgres://..." \
    #     --from-literal=analytics-database-url="postgres://..." \
    #     --from-literal=jwt-secret="..." \
    #     --from-literal=db-user="..." \
    #     --from-literal=db-password="..." \
    #     --dry-run=client -o yaml | kubeseal --controller-namespace=sealed-secrets -o yaml
    database-url: <sealed-secret-value>
    analytics-database-url: <sealed-secret-value>
    jwt-secret: <sealed-secret-value>
    db-user: <sealed-secret-value>
    db-password: <sealed-secret-value>
