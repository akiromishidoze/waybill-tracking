# Copy this file to backend.tfbackend, fill in real values, and run:
#   terraform init -backend-config=backend.tfbackend -migrate
#
# Or pass via CLI:
#   terraform init -backend-config="bucket=waybill-tfstate-<env>" \
#                  -backend-config="prefix=terraform/gcp" \
#                  -migrate

bucket = "waybill-tfstate-<ENV>"
prefix = "terraform/gcp"