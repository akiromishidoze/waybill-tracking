# Server
PORT=8080

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/waybill?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=waybill-events

# JWT
JWT_SECRET=change-me-in-production
# JWT_SECRET_FILE=/run/secrets/jwt_secret   # alternative to JWT_SECRET
# JWT_SECRET_OLD=                            # previous secret for key rotation

# Twilio (SMS notifications — optional)
TWILIO_SID=
TWILIO_AUTH_TOKEN=

# SendGrid (email notifications — optional)
SENDGRID_KEY=

# Migrations
MIGRATIONS_DIR=migrations

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3010
