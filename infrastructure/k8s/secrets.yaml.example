apiVersion: v1
kind: Secret
metadata:
  name: waybill-secrets
  namespace: waybill
  annotations:
    # Do not commit this file with real values. Generate a sealed secret or use
    # an external secrets operator (e.g. External Secrets, SOPS, Vault) instead.
    note: "Example only — copy to secrets.yaml and fill in real values, or use a sealed/external secret."
type: Opaque
stringData:
  # PostgreSQL connection string for core-api
  database-url: "postgres://<user>:<password>@postgres:5432/<dbname>?sslmode=disable"
  # PostgreSQL connection string for analytics-api
  analytics-database-url: "postgres://<user>:<password>@postgres:5432/<dbname>?sslmode=disable"
  # Strong random JWT secret (at least 32 characters)
  jwt-secret: "<replace-with-a-long-random-secret>"
  # PostgreSQL bootstrap credentials (used by init jobs or Helm values)
  db-user: "<replace-me>"
  db-password: "<replace-me>"
